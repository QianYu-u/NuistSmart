<Page
    x:Class="NuistSmart.Views.BookDetailPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 顶部工具栏 -->
        <Grid Grid.Row="0" Padding="12,8" Background="{ThemeResource LayerFillColorDefaultBrush}"
              BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}" BorderThickness="0,0,0,1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 返回按钮 -->
            <Button Grid.Column="0" 
                    x:Name="BackButton"
                    Click="BackButton_Click"
                    Style="{StaticResource SubtleButtonStyle}"
                    ToolTipService.ToolTip="返回图书列表">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon Glyph="&#xE72B;" FontSize="14"/>
                    <TextBlock Text="返回" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>

            <!-- 标题 -->
            <TextBlock Grid.Column="1" 
                       x:Name="PageTitle"
                       Text="图书详情" 
                       VerticalAlignment="Center"
                       HorizontalAlignment="Center"
                       FontSize="14"
                       FontWeight="SemiBold"
                       Opacity="0.85"/>

            <!-- 在浏览器中打开 -->
            <Button Grid.Column="2"
                    x:Name="OpenInBrowserButton"
                    Click="OpenInBrowser_Click"
                    Style="{StaticResource SubtleButtonStyle}"
                    ToolTipService.ToolTip="在浏览器中打开">
                <FontIcon Glyph="&#xE774;" FontSize="14"/>
            </Button>
        </Grid>

        <!-- WebView2 主体 -->
        <Grid Grid.Row="1">
            <!-- 加载进度条 -->
            <ProgressBar x:Name="LoadingBar" 
                         IsIndeterminate="True"
                         VerticalAlignment="Top"
                         Visibility="Visible"/>
            
            <WebView2 x:Name="DetailWebView"/>
        </Grid>
    </Grid>
</Page>
