<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="NuistSmart.Views.LoginPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:NuistSmart.Views"
    xmlns:viewmodels="using:NuistSmart.ViewModels"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d"
    Background="Transparent">

    <!-- 设置 Page 的 DataContext 为 LoginViewModel -->
    <Page.DataContext>
        <viewmodels:LoginViewModel />
    </Page.DataContext>

    <!-- 主容器：两行布局（主内容区 + 底部栏），带半透明灰色蒙版 -->
    <Grid>
        <!-- 全屏半透明蒙版，营造磨砂玻璃质感 -->
        <Grid.Background>
            <SolidColorBrush Color="#000000" Opacity="0.15"/>
        </Grid.Background>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- ============ Row 0: 主内容区（左右分栏：4* 和 6*） ============ -->
        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="4*"/>
                <ColumnDefinition Width="6*"/>
            </Grid.ColumnDefinitions>

            <!-- ============ 左侧展示区：Logo + 标题 + 动态公告栏 ============ -->
            <Grid Grid.Column="0">
                <StackPanel 
                    VerticalAlignment="Center" 
                    HorizontalAlignment="Center"
                    Spacing="12" 
                    Padding="40">
                    
                    <!-- Logo 图片 -->
                    <Image 
                        Source="ms-appx:///Assets/NuistLogo.png"
                        Width="90"
                        Height="90"
                        Stretch="Uniform"
                        HorizontalAlignment="Center"/>
                    
                    <!-- 标题 -->
                    <TextBlock 
                        Text="NuistSmart"
                        FontSize="36"
                        FontWeight="Bold"
                        HorizontalAlignment="Center"
                        Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>

                    <!-- 动态公告栏（半透明圆角卡片） -->
                    <Border 
                        Background="{ThemeResource LayerFillColorDefaultBrush}"
                        CornerRadius="12"
                        Padding="24"
                        MaxWidth="400"
                        BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                        BorderThickness="1">
                        
                        <StackPanel Spacing="12">
                            <TextBlock 
                                Text="📢 系统公告"
                                FontSize="16"
                                FontWeight="SemiBold"
                                Foreground="{ThemeResource TextFillColorPrimaryBrush}"/>
                            
                            <ScrollViewer 
                                MaxHeight="180"
                                VerticalScrollBarVisibility="Auto"
                                HorizontalScrollBarVisibility="Disabled">
                                <TextBlock 
                                    Text="{x:Bind ViewModel.AnnouncementText, Mode=OneWay}"
                                    TextWrapping="Wrap"
                                    FontSize="13"
                                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                    LineHeight="22"/>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>

            <!-- ============ 右侧登录区：CAS WebView2 容器 ============ -->
            <Grid Grid.Column="1">
                <Border 
                    VerticalAlignment="Center"
                    HorizontalAlignment="Center"
                    Width="400"
                    Height="500"
                    Background="{ThemeResource CardBackgroundFillColorDefaultBrush}"
                    CornerRadius="8"
                    BorderBrush="{ThemeResource CardStrokeColorDefaultBrush}"
                    BorderThickness="1">
                    
                    <Border.Shadow>
                        <ThemeShadow />
                    </Border.Shadow>
                    
                    <!-- CoreWebView2 必须被设置 CornerRadius 以应用到上层 Border 的裁切效果中（WinUI 3 内部处理） 
                         不过可以直接用 Grid 包含 WebView2 并在外部裁切 -->
                    <Grid CornerRadius="8" Background="Transparent">
                        <WebView2 x:Name="LoginWebView" />
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ============ Row 1: 底部栏 ============ -->
        <Grid 
            Grid.Row="1" 
            Height="38"
            Background="{ThemeResource LayerFillColorDefaultBrush}"
            Padding="20,0">
            
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- 左下角：版本号 -->
            <TextBlock 
                Grid.Column="0"
                Text="Version 1.0.0"
                VerticalAlignment="Center"
                FontSize="12"
                Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

            <!-- 右下角：GitHub 链接 -->
            <Button
                Grid.Column="1"
                Background="Transparent"
                BorderThickness="0"
                VerticalAlignment="Center"
                Padding="8,4"
                Click="OnGitHubButtonClick">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <FontIcon 
                        Glyph="&#xE71B;" 
                        FontSize="14"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                    <TextBlock 
                        Text="GitHub" 
                        FontSize="12"
                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>
                </StackPanel>
            </Button>
        </Grid>
    </Grid>
</Page>
